# OpenCode API server settings
OPENCODE_API_PORT=4096
OPENCODE_API_HOST=127.0.0.1

# Pi settings
# Working directory for Pi (defaults to current dir)
PI_WORKING_DIR=.

# Pi will use its own configuration for the model and API keys
# Make sure your API key is set in the environment, e.g.:
# export ANTHROPIC_API_KEY=sk-ant-...
